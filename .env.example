# Copy to .env (gitignored) and fill in your values.

# Required for crowbuster.py
ANTHROPIC_API_KEY=sk-ant-...

# Optional — push a phone notification on the HUMAN ALARM escalation only
# (NOT on routine speaker fires). Leave unset to disable.
#   1. Pick a hard-to-guess topic name. Anyone with the name can read your
#      alerts, so don't pick something obvious.
#   2. Install the "ntfy" app (iOS / Android / web) and subscribe to the topic.
#   3. Uncomment and set the value below.
# CROWBUSTER_NTFY_TOPIC=crowbuster-changeme-xxxxxxxx
# CROWBUSTER_NTFY_SERVER=https://ntfy.sh    # uncomment + change for self-hosted

# Required for sync.sh (only if you're auto-syncing from a dev machine)
REMOTE_USER=your-username
REMOTE_HOST=192.168.1.x
REMOTE_PATH=crowbuster/        # relative to remote user's home; don't use ~ (gets expanded locally)
